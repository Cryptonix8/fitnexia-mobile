{
  "expo": {
    "name": "Fitnexia",
    "slug": "Fitnexia",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/simbolo.png",
    "scheme": "fitnexia",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.fitnexia.app",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Fitnexia usa tu ubicación para mostrarte clases cerca tuyo en el mapa."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff",
        "foregroundImage": "./assets/images/simbolo.png"
      },
      "googleServicesFile": "./google-services.json",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "package": "com.fitnexia.app"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/simbolo.png"
    },
    "plugins": [
      "expo-dev-client",
      "@react-native-firebase/app",
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static"
          }
        }
      ],
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Fitnexia necesita acceso a tus fotos para que puedas elegir una foto de perfil."
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#ffffff",
          "ios": {
            "image": "./assets/images/splash-full.png",
            "imageWidth": 280,
            "resizeMode": "contain",
            "backgroundColor": "#ffffff",
            "dark": {
              "image": "./assets/images/splash-full.png",
              "backgroundColor": "#ffffff"
            }
          },
          "android": {
            "image": "./assets/images/simbolo.png",
            "imageWidth": 200,
            "resizeMode": "contain",
            "backgroundColor": "#ffffff",
            "dark": {
              "image": "./assets/images/simbolo.png",
              "backgroundColor": "#ffffff"
            }
          }
        }
      ],
      "@react-native-community/datetimepicker",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Fitnexia usa tu ubicación para mostrarte clases cerca tuyo en el mapa."
        }
      ],
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.635752178238-ggnibnda2tseudchjo5nrsk1re55kcon"
        }
      ],
      "expo-localization",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/simbolo.png",
          "color": "#2563eb",
          "defaultChannel": "fitnexia_default"
        }
      ],
      "@react-native-firebase/analytics"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e43c4a54-4440-477d-a032-1c6c87144ecf"
      }
    },
    "owner": "antonia0527"
  }
}
