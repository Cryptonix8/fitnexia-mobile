# iOS simulator / web
EXPO_PUBLIC_API_URL=http://localhost:3001/v1

# Google OAuth — Web client ID (required). Used as webClientId for native sign-in + backend token verify.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
# Create a separate Android OAuth client in Google Cloud (package + SHA-1). No env var needed on mobile.
# Optional iOS client ID if you build for iOS:
# EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=

# Android emulator — use instead of localhost:
# EXPO_PUBLIC_API_URL=http://10.0.2.2:3001/v1

# Physical device — use your machine LAN IP:
# EXPO_PUBLIC_API_URL=http://192.168.1.100:3001/v1
