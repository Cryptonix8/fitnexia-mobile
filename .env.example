# iOS simulator / web
EXPO_PUBLIC_API_URL=http://localhost:3001/v1

# Web client ID only — used as webClientId in the app. Do NOT paste the Android OAuth client ID here.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
# Android OAuth client in Google Cloud must use package com.fitnexia.app + your APK SHA-1.
# EAS builds: run `eas credentials` → Android → copy SHA-1 into Google Cloud (and optionally below).
# EXPO_PUBLIC_GOOGLE_ANDROID_SHA1=AA:BB:CC:...
# Optional iOS client ID if you build for iOS:
# EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=

# Android emulator — use instead of localhost:
# EXPO_PUBLIC_API_URL=http://10.0.2.2:3001/v1

# Physical device — use your machine LAN IP:
# EXPO_PUBLIC_API_URL=http://192.168.1.100:3001/v1

# Push on Android emulator: use a dev build (npx expo run:android), not Expo Go.
# Emulator AVD must include Google Play. Backend needs secrets/firebase-service-account.json.
# After login, send a test push: POST /v1/notifications/test-push (dev only, Bearer token)

# Must match Mercado Pago account country (UY → UYU, AR → ARS, MX → MXN)
EXPO_PUBLIC_DEFAULT_CURRENCY=UYU

# Mercado Pago sandbox public key (optional — checkout is server-side today)
# EXPO_PUBLIC_MERCADO_PAGO_PUBLIC_KEY=TEST-your-public-key
